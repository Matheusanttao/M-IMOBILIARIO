# Supabase (Project Settings > API)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudinary — use um upload preset UNSIGNED (Settings > Upload > Upload presets)
# Não coloque API Secret no frontend. Para exclusão segura de imagens, use Edge Function ou backend.
VITE_CLOUDINARY_CLOUD_NAME=seu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=seu_upload_preset_unsigned

# WhatsApp (DDI + DDD + número, só dígitos, ex: 5511999998888)
VITE_WHATSAPP_NUMBER=5511999998888
