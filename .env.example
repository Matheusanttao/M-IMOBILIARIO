# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Tenant padrão em localhost (slug em public.empresas)
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo

# Site (SEO / sitemap)
NEXT_PUBLIC_SITE_URL=https://seu-dominio.vercel.app

# Cloudinary — upload preset UNSIGNED
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=seu_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=seu_upload_preset_unsigned

# WhatsApp fallback (DDI + DDD + número, só dígitos)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999998888

# Mercado Pago (webhook Next.js ou Edge Function)
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=

# Supabase Service Role (server-side, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Domínio base para resolução de subdomínios (ex: seudominio.com.br)
NEXT_PUBLIC_BASE_DOMAIN=

# IA (opcional — rota /api/ai/descricao)
OPENAI_API_KEY=
